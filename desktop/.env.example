# Copy to .env.local for local WDIM connector testing.
# Do not commit .env.local.

# Native OAuth client configuration. Tokens stay encrypted on the user's Mac.
WDIM_GMAIL_CLIENT_ID=
WDIM_GMAIL_CLIENT_SECRET=

# Optional legacy X / Twitter OAuth fallback. The default X connector reads the
# browser session via the bundled bird CLI and needs no configuration.
WDIM_TWITTER_CLIENT_ID=
WDIM_TWITTER_REDIRECT_URI=http://127.0.0.1:53145/oauth/callback/twitter

# Dev scripts default this to 1 so local launches do not immediately poll live accounts.
WDIM_SKIP_INITIAL_SCAN=1
