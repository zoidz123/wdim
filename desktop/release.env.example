# Copy to a private shell profile or export these before running `bun run dist:signed`.
# Do not commit real values.

# Apple signing identity. Install a "Developer ID Application" certificate in Keychain first.
# You can check available identities with:
#   security find-identity -v -p codesigning
CSC_NAME="Your Name (TEAMID)"

# Recommended notarization path: App Store Connect API key.
# Create this in App Store Connect > Users and Access > Integrations > App Store Connect API.
APPLE_API_KEY="/absolute/path/AuthKey_XXXXXXXXXX.p8"
APPLE_API_KEY_ID="XXXXXXXXXX"
APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Alternative notarization path if you do not use API keys:
# APPLE_ID="you@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="TEAMID"
