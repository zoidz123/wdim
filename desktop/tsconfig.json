{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "bun", "electron"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"]
}
